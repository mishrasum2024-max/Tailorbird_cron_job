  "bugs": {
    "url": "https://github.com/Harshalogy/Tailorbird_ui_automation/issues"
  },
  "homepage": "https://github.com/Harshalogy/Tailorbird_ui_automation#readme",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.1"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
